############################################
# App
############################################
APP_NAME="O'Level Study Help"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=

############################################
# Logging
############################################
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

############################################
# Database
############################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=

############################################
# Queue / Cache / Session
############################################
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database-uuids
CACHE_DRIVER=file
CACHE_PREFIX=
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false

############################################
# Redis
############################################
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=
REDIS_URL=

############################################
# Memcached (optional)
############################################
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

############################################
# Mail
############################################
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_URL=

############################################
# Filesystem / S3-compatible storage (optional)
############################################
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=
AWS_ENDPOINT=

############################################
# Billing & access gating
# (Most billing rules are DB-driven; no extra env keys required)
############################################

############################################
# AI grading (OpenAI)
############################################
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_GRADING_MODEL=gpt-4.1-mini
OPENAI_MODEL_LOW_COST=gpt-4.1-mini
OPENAI_MODEL_HIGH_ACCURACY=gpt-4.1
OPENAI_MODEL_FALLBACK=gpt-4.1
OPENAI_TIMEOUT_SECONDS=30
OPENAI_GRADING_QUEUE=default
OPENAI_GRADING_BATCH_SIZE=5
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_MAX_FEEDBACK_CHARS=220
OPENAI_GRADING_RETRY_COUNT=2
OPENAI_CONFIDENCE_MANUAL_REVIEW_THRESHOLD=0.55
OPENAI_ESCALATION_CONFIDENCE_THRESHOLD=0.45
OPENAI_ENABLE_CACHING=true
OPENAI_CACHE_TTL_SECONDS=2592000
OPENAI_CACHE_VERSION=theory-v2

############################################
# Imports
############################################
IMPORT_PROCESSING_QUEUE=default

############################################
# Broadcasting (Pusher protocol / Reverb compatible)
############################################
BROADCAST_DRIVER=pusher

# Pusher-compatible credentials (used by broadcast driver "pusher")
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Reverb credentials/host (used by reverb connection if selected)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=
REVERB_SCALING_ENABLED=false
REVERB_SCALING_CHANNEL=reverb

# Frontend broadcasting env
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

NOTIFICATIONS_QUEUE=default
STUDY_NOTIFICATIONS_ENABLED=true
STUDY_STUDENT_REMINDERS_ENABLED=true
STUDY_ADMIN_ALERTS_ENABLED=true
STUDY_REMINDER_INACTIVITY_ENABLED=true
STUDY_REMINDER_INACTIVITY_DAYS=7
STUDY_REMINDER_INACTIVITY_COOLDOWN_HOURS=24
STUDY_REMINDER_PENDING_VERIFICATION_ENABLED=true
STUDY_REMINDER_PENDING_MIN_HOURS=12
STUDY_REMINDER_PENDING_COOLDOWN_HOURS=24
STUDY_REMINDER_DRAFT_QUIZ_ENABLED=true
STUDY_REMINDER_DRAFT_INACTIVE_MINUTES=120
STUDY_REMINDER_DRAFT_COOLDOWN_HOURS=24
STUDY_ADMIN_ALERTS_COOLDOWN_HOURS=6
STUDY_ADMIN_MANUAL_REVIEW_THRESHOLD=20
STUDY_ADMIN_GRADING_FAILURE_WINDOW_HOURS=24
STUDY_ADMIN_IMPORT_FAILURE_WINDOW_HOURS=24
